APP_ENV=local
LOG_LEVEL=INFO

# local: Ollama Qwen + Chroma
LLM_PROVIDER=ollama
RAG_PROVIDER=chroma
LOCAL_LLM_MODEL=qwen2.5:7b
LOCAL_EMBEDDING_MODEL=bge-m3
CHROMA_DIR=.vectorstore/aws_cert
CHROMA_COLLECTION=aws_cert_knowledge
KNOWLEDGE_DIR=data/knowledge

# aws: Bedrock Qwen + Bedrock Knowledge Base
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=qwen.qwen3-32b
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_KNOWLEDGE_BASE_ID=

TEMPERATURE=0.1
TOP_K=5
